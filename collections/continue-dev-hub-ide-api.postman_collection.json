              "description": "Whether to always use the Continue-managed proxy for model requests"
            },
            {
              "disabled": false,
              "key": "organizationId",
              "value": "<string>",
              "description": "ID of the organization to scope assistants to. If not provided, personal assistants are returned."
            }
